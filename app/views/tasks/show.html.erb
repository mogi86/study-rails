<div class="container mx-auto px-4 py-8">
  <div class="max-w-2xl mx-auto">
    <div class="mb-6">
      <%= link_to tasks_path, class: "inline-flex items-center text-blue-600 hover:text-blue-800" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        タスク一覧に戻る
      <% end %>
    </div>

    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <h1 class="text-2xl font-bold text-gray-900">タスク詳細</h1>
          <div class="flex items-center space-x-2">
            <%= link_to edit_task_path(@task),
                        class: "inline-flex items-center px-3 py-2 border border-transparent
                               text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" do %>
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
              編集
            <% end %>
          </div>
        </div>

        <div class="space-y-4">
          <div>
            <h3 class="text-lg font-medium text-gray-900 mb-2">タスク名</h3>
            <p class="text-gray-700 <%= 'line-through' if @task.completed %>">
              <%= @task.title %>
            </p>
          </div>

          <% if @task.description.present? %>
            <div>
              <h3 class="text-lg font-medium text-gray-900 mb-2">詳細</h3>
              <div class="text-gray-700 <%= 'line-through' if @task.completed %>">
                <%= simple_format(@task.description) %>
              </div>
            </div>
          <% end %>

          <div class="flex items-center space-x-4 text-sm text-gray-500">
            <span>作成日時: <%= @task.created_at.strftime("%Y年%m月%d日 %H:%M") %></span>
            <span>更新日時: <%= @task.updated_at.strftime("%Y年%m月%d日 %H:%M") %></span>
          </div>

          <div class="flex items-center justify-between pt-4 border-t border-gray-200">
            <div class="flex items-center">
              <% if @task.completed %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm
                           font-medium bg-green-100 text-green-800">
                  ✓ 完了
                </span>
              <% else %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm
                           font-medium bg-yellow-100 text-yellow-800">
                  ⏳ 未完了
                </span>
              <% end %>
            </div>

            <div class="flex items-center space-x-2">
              <%= link_to toggle_complete_task_path(@task),
                          method: :patch,
                          class: "inline-flex items-center px-3 py-2 border border-gray-300
                                 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
                <% if @task.completed %>
                  未完了に戻す
                <% else %>
                  完了にする
                <% end %>
              <% end %>

              <%= link_to @task,
                          method: :delete,
                          data: { confirm: "本当に削除しますか？" },
                          class: "inline-flex items-center px-3 py-2 border border-transparent
                                 text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700" do %>
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
                削除
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
